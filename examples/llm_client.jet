# ステートフルLLMクライアント
# Usage: ./jet -r LlmClient::LlmClient.demo examples/llm_client.jet
#
# 環境変数 ANTHROPIC_API_KEY を設定してから実行してください

class LlmClient
  def self.demo()
    api_key = os::getenv("ANTHROPIC_API_KEY")

    # デフォルト設定でクライアント作成
    client = Llm::Client.new(:claude, api_key)

    io::format("=== Simple chat ===~n", [])
    response = client.chat("You are a helpful assistant. Reply briefly.", "What is the BEAM virtual machine?")
    io::format("~s~n~n", [response])

    # カスタム設定でクライアント作成
    client2 = Llm::Client.new(:claude, api_key, {model: "claude-sonnet-4-20250514", max_tokens: 256})

    io::format("=== Multi-turn conversation ===~n", [])
    response2 = client2.complete(
      "You are a programming language expert. Reply briefly.",
      [{:user, "What is Jet?"},
       {:assistant, "I'm not sure I know about a language called Jet. Could you tell me about it?"},
       {:user, "It's a language that compiles to BEAM bytecode with Ruby-like syntax!"}])
    io::format("~s~n", [response2])
  end
end
