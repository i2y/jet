# ReviewMockDemo — test review loop with mock runner (fast, no Claude)
#
# Verifies: comment detection → review task → workspace reuse → hook execution → push

module ReviewMockDemo
  def self.run()
    puts("=== Review Mock Demo ===\n")

    repo = "i2y/orchestra-test"
    os::putenv("ORCHESTRA_GITHUB_REPO", repo)
    erlang::put(:orchestra_github_repo, repo)
    root = "/tmp/orchestra_debug"

    config = Config::new({
      mode: :push,
      max_concurrent: 1,
      max_turns: 1,
      max_retries: 0,
      max_review_rounds: 5,
      review_poll_interval_ms: 5000,
      workspace_root: root
    })

    hooks = {
      before_run: "true",
      after_run: "true",
      before_review_run: "cd " ++ root ++ "/1 && git fetch origin && git pull --no-edit 2>/dev/null; true",
      after_review_run: "cd " ++ root ++ "/1 && git add -A && git diff --cached --stat && git commit -m '[orchestra] address review feedback' --allow-empty && git push 2>&1; true"
    }

    # Seed checkpoint
    seed(root)

    orch = Scheduler::Instance.spawn(config, nil, nil, {
      store: :FileStore,
      review_source: :GitHubPRReviewSource,
      hooks: hooks
    })

    puts("Waiting for review task detection...\n")
    wait_loop(orch, 0, 60)
  end

  def self.seed(root)
    dir = root ++ "/.orchestra"
    filelib::ensure_dir(dir ++ "/dummy")
    json = jet_json_ffi::encode({
      <<"version">> => 1,
      <<"created_at">> => erlang::system_time(:millisecond),
      <<"claimed">> => [<<"1">>],
      <<"retry_attempts">> => {},
      <<"done">> => {<<"1">> => true},
      <<"completed">> => [{<<"task_id">> => <<"1">>, <<"status">> => <<"ok">>, <<"output">> => <<"fixed">>}],
      <<"review_pending">> => {<<"1">> => {<<"pr_number">> => 2, <<"round">> => 0}}
    })
    file::write_file(dir ++ "/checkpoint.json", json)
    puts("Checkpoint seeded")
  end

  def self.wait_loop(orch, elapsed, max_seconds)
    if elapsed >= max_seconds
      puts("\nTimeout")
      gen_server::stop(orch)
    else
      timer::sleep(5000)
      status = orch.status()
      completed_count = maps::get(:completed, status)
      running = maps::get(:running, status)
      puts("[~ps] running=~p completed=~p", [elapsed + 5, running, completed_count])

      if completed_count > 1 and running == 0
        puts("\n=== Review task completed! ===")
        completed = orch.completed()
        print_results(completed)

        # Check if push happened
        puts("\n=== Checking git log ===")
        log_output = os::cmd("cd /tmp/orchestra_debug/1 && git log --oneline -3 2>&1")
        puts(log_output)

        gen_server::stop(orch)
      else
        wait_loop(orch, elapsed + 5, max_seconds)
      end
    end
  end

  def self.print_results([])
    :ok
  end

  def self.print_results([{id, result_status, _output}, *rest])
    puts("  ~s: ~p", [id, result_status])
    print_results(rest)
  end
end
