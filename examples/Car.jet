class Car
  include parent, parent2

  def initialize()
    @name = "car1"
    @speed = 100
    self
  end

  def self.test()
    "Elixir.IO"::inspect(1000)
    car = Car::Car.new()
    car.class_info().display()
  end

  def inspect()
    "Elixir.IO"::inspect(@name)
    "Elixir.IO"::inspect(@speed)
  end
end