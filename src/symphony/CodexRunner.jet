# Symphony CodexRunner — runs Codex via app-server (JSON-RPC over stdio)
#
# Implements the AgentRunner interface.
# Launches `codex` as an external process and communicates via JSON-RPC.

module CodexRunner
  def self.run(workspace, prompt, callback_pid)
    cmd = "cd " ++ workspace ++ " && codex --quiet --json"
    match jet_port_ffi::open(cmd, [:binary, {:line, 65536}, :exit_status, :use_stdio])
      case {:ok, port}
        # Send the prompt via JSON-RPC
        request = jet_json_ffi::encode({
          <<"jsonrpc">> => <<"2.0">>,
          <<"method">> => <<"run">>,
          <<"params">> => {<<"prompt">> => erlang::list_to_binary(prompt)},
          <<"id">> => 1
        })
        input = erlang::iolist_to_binary([request, "\n"])
        jet_port_ffi::send_input(port, input)
        # Spawn a reader process to forward events
        reader = erlang::spawn(do ||
          CodexRunner::read_loop(port, callback_pid)
        end)
        erlang::put({:codex_port, workspace}, {port, reader})
        :ok
      case {:error, reason}
        callback_pid ! {:agent_done, {status: :error, output: reason}}
        {:error, reason}
    end
  end

  def self.stop(workspace)
    match erlang::get({:codex_port, workspace})
      case :undefined
        :ok
      case {port, _reader}
        jet_port_ffi::close(port)
        erlang::erase({:codex_port, workspace})
        :ok
    end
  end

  def self.read_loop(port, callback_pid)
    receive
      case {port, {:data, {:eol, line}}}
        match jet_json_ffi::decode(line)
          case {:ok, parsed}
            # Check if it's a final result or streaming event
            if maps::is_key(<<"result">>, parsed)
              result = maps::get(<<"result">>, parsed)
              callback_pid ! {:agent_done, {status: :ok, output: result, completed: true}}
            elsif maps::is_key(<<"error">>, parsed)
              err = maps::get(<<"error">>, parsed)
              callback_pid ! {:agent_done, {status: :error, output: err}}
            else
              callback_pid ! {:agent_event, parsed}
              CodexRunner::read_loop(port, callback_pid)
            end
          case {:error, _}
            # Non-JSON output, forward as event
            callback_pid ! {:agent_event, {type: :output, text: binary_to_list(line)}}
            CodexRunner::read_loop(port, callback_pid)
        end
      case {port, {:exit_status, 0}}
        callback_pid ! {:agent_done, {status: :ok, output: "exited normally", completed: true}}
      case {port, {:exit_status, code}}
        callback_pid ! {:agent_done, {status: :error, output: "exit code: " ++ integer_to_list(code)}}
    after 300000
      callback_pid ! {:agent_done, {status: :error, output: "timeout"}}
    end
  end
end
