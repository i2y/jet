# Symphony ClaudeCodeRunner — runs Claude Code via CLI
#
# Implements the AgentRunner interface.
# Launches `claude --print` as an external process.

module ClaudeCodeRunner
  def self.run(workspace, prompt, callback_pid)
    # Escape the prompt for shell
    escaped_prompt = escape_shell(prompt)
    cmd = "cd " ++ workspace ++ " && claude --print " ++ escaped_prompt
    match jet_port_ffi::open(cmd, [:binary, {:line, 65536}, :exit_status, :use_stdio])
      case {:ok, port}
        # Spawn a reader process to forward output
        reader = erlang::spawn(do ||
          ClaudeCodeRunner::read_loop(port, callback_pid, [])
        end)
        erlang::put({:claude_port, workspace}, {port, reader})
        :ok
      case {:error, reason}
        callback_pid ! {:agent_done, {status: :error, output: reason}}
        {:error, reason}
    end
  end

  def self.stop(workspace)
    match erlang::get({:claude_port, workspace})
      case :undefined
        :ok
      case {port, _reader}
        jet_port_ffi::close(port)
        erlang::erase({:claude_port, workspace})
        :ok
    end
  end

  def self.read_loop(port, callback_pid, acc)
    receive
      case {port, {:data, {:eol, line}}}
        text = binary_to_list(line)
        callback_pid ! {:agent_event, {type: :output, text: text}}
        ClaudeCodeRunner::read_loop(port, callback_pid, [text, *acc])
      case {port, {:data, {:noeol, line}}}
        text = binary_to_list(line)
        callback_pid ! {:agent_event, {type: :output, text: text}}
        ClaudeCodeRunner::read_loop(port, callback_pid, [text, *acc])
      case {port, {:exit_status, 0}}
        output = lists::flatten(lists::reverse(acc))
        callback_pid ! {:agent_done, {status: :ok, output: output, completed: true}}
      case {port, {:exit_status, code}}
        output = lists::flatten(lists::reverse(acc))
        callback_pid ! {:agent_done, {status: :error, output: output ++ "\nexit code: " ++ integer_to_list(code)}}
    after 600000
      callback_pid ! {:agent_done, {status: :error, output: "timeout"}}
    end
  end

  # Escape a string for shell use (single-quote wrapping)
  def self.escape_shell(str)
    escaped = re::replace(str, "'", "'\\''", [:global, {:return, :list}])
    "'" ++ escaped ++ "'"
  end
end
